#
# APPLICATION ENVIRONMENT
#
# When set to dev, errors are displayed.
# When set to production, errors are hidden.
# APP_ENV=dev
APP_ENV=production

#
# APPLICATION URL (optional)
#
# Set this if the auto-detection fails, e.g. behind a reverse proxy.
# Keeping this in .env ensures it survives application upgrades.
#
# APPLICATION_URL=http://your-domain.com/tcneo/

#
# DATABASE CONNECTION
#
DB_HOST=localhost
DB_PORT=3306
# Enable the port setting if your database server requires it (instead of ip binding)
# DB_SOCKET=/var/run/mysqld/mysqld.sock
DB_NAME=teamcal_neo
DB_USER=db_user
DB_PASS=db_secret_password
DB_PREFIX=tcneo_

#
# INSTALLATION FLAG
#
# Set to 1 after the installation script has been run successfully.
# Set to 0 to run the installation script again.
# Keeping this in .env ensures it survives application upgrades.
#
APP_INSTALLED=1

#
# OIDC AUTHENTICATION (optional)
#
# Set OIDC_YES=1 to enable OpenID Connect (OIDC) authentication.
# When enabled, local and LDAP login are disabled for all users except 'admin'.
# The admin user always authenticates against the TeamCal Neo database.
# Keeping these settings in .env ensures they survive application upgrades.
#
# OIDC_YES=0
# OIDC_PROVIDER_URL=https://keycloak.example.com/realms/teamcalneo
# OIDC_CLIENT_ID=teamcal-neo
# OIDC_CLIENT_SECRET=your-client-secret-here
# OIDC_REDIRECT_URI=https://your-teamcal-server.com/index.php?action=oidccallback

#
# LDAP AUTHENTICATION (optional)
#
# Set LDAP_YES=1 to enable LDAP authentication.
# Keeping these settings in .env ensures they survive application upgrades.
# The admin user always authenticates against the TeamCal Neo database.
#
# LDAP_YES=0
# LDAP_ADS=0
# LDAP_HOST=ldap.example.com
# LDAP_PORT=389
# LDAP_PASS=secret_password
# LDAP_DIT=cn=read-only-admin,dc=example,dc=com
# LDAP_SBASE=dc=example,dc=com
# LDAP_TLS=0
# LDAP_CHECK_ANONYMOUS_BIND=0
# LDAP_SEARCH_BIND=0
