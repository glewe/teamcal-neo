{
    "name": "glewe/teamcal-neo",
    "version": "5.0.6",
    "build": "40",
    "description": "A web application of a day-based calendar and scheduling tool.",
    "type": "project",
    "license": "GPL-3.0-or-later (see LICENSE file)",
    "authors": [
        {
            "name": "George Lewe",
            "email": "george@lewe.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://www.lewe.com",
    "require": {
        "ext-ctype": "*",
        "ext-pdo": "*",
        "matthiasmullie/minify": "^1.3",
        "phpmailer/phpmailer": "^7.0",
        "robthree/twofactorauth": "^2.0",
        "twig/twig": "^3.22",
        "vlucas/phpdotenv": "^5.6",
        "ezyang/htmlpurifier": "^4.19"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.1",
        "symfony/process": "6.4.33",
        "cyclonedx/cyclonedx-php-composer": "^6.1",
        "phpseclib/phpseclib": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "build": "php tools/build.php",
        "deploy": "php tools/deploy.php",
        "build:deploy": [
            "@build",
            "@deploy"
        ],
        "docs": "php tools/docs.php && php tools/apply_dark_mode.php",
        "minify": "php tools/minify.php",
        "phpunit": "phpunit",
        "phpstan": "php vendor/bin/phpstan analyse",
        "phpstan:baseline": "php vendor/bin/phpstan analyse --generate-baseline",
        "sbom": "composer CycloneDX:make-sbom --output-format=JSON --output-file=bom.json",
        "release": "php tools/release.php",
        "release:force": "php tools/release.php --force",
        "update-version": "php tools/update_version.php"
    },
    "config": {
        "process-timeout": 0,
        "allow-plugins": {
            "cyclonedx/cyclonedx-php-composer": true
        }
    }
}
